@model TechMoveGLMS.Models.ServiceRequest
@using TechMoveGLMS.Models

@{
    ViewData["Title"] = "Service Request Details";
}

<div class="card">
    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0"><i class="fas fa-clipboard-list"></i> @Model.Title</h3>
        <div>
            <a href="/ServiceRequests" class="btn btn-light">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <h4>Request Information</h4>
                <table class="table table-bordered">
                    <tr>
                        <th style="width: 200px;">Request ID</th>
                        <td>#@Model.Id</td>
                    </tr>
                    <tr>
                        <th>Contract</th>
                        <td>@Model.Contract?.Title</td>
                    </tr>
                    <tr>
                        <th>Client</th>
                        <td>@Model.Contract?.Client?.Name</td>
                    </tr>
                    <tr>
                        <th>Client Contact</th>
                        <td>
                            @Model.Contract?.Client?.Email<br />
                            @Model.Contract?.Client?.Phone
                        </td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>@Model.Description</td>
                    </tr>
                    <tr>
                        <th>Amount (USD)</th>
                        <td class="fw-bold">$@Model.AmountUSD.ToString("N2")</td>
                    </tr>
                    <tr>
                        <th>Exchange Rate Used</th>
                        <td>1 USD = @Model.ExchangeRate.ToString("F2") ZAR</td>
                    </tr>
                    <tr>
                        <th>Amount (ZAR)</th>
                        <td class="fw-bold text-success">R@(Model.AmountZAR.ToString("N2"))</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>
                            <span class="status-badge status-@Model.Status">
                                @Model.Status
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <th>Request Date</th>
                        <td>@Model.RequestDate.ToString("MMMM dd, yyyy HH:mm")</td>
                    </tr>
                    @if (Model.CompletedDate.HasValue)
                    {
                        <tr>
                            <th>Completed Date</th>
                            <td>@Model.CompletedDate.Value.ToString("MMMM dd, yyyy HH:mm")</td>
                        </tr>
                    }
                </table>

                <!-- Update Status Section -->
                <div class="card mt-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-sync-alt"></i> Update Request Status</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="UpdateStatus" asp-controller="ServiceRequests" method="post" class="row g-3">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="col-md-6">
                                <select name="status" class="form-select">
                                    @foreach (RequestStatus status in Enum.GetValues(typeof(RequestStatus)))
                                    {
                                        <option value="@status" selected="@(Model.Status == status)">
                                            @status
                                        </option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Update Status
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- INVOICE SECTION - Generate Invoice Button -->
                @if (Model.Status == RequestStatus.Completed || Model.Status == RequestStatus.Approved)
                {
                    <div class="card mt-4 border-info">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0"><i class="fas fa-file-invoice-dollar"></i> Invoice Generation</h5>
                        </div>
                        <div class="card-body">
                            <p>This service request is ready to be invoiced.</p>
                            <a href="/Invoices/Create/@Model.Id" class="btn btn-success btn-lg">
                                <i class="fas fa-file-invoice"></i> Generate Invoice
                            </a>
                        </div>
                    </div>
                }
                else if (Model.Status == RequestStatus.Pending)
                {
                    <div class="card mt-4 border-warning">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0"><i class="fas fa-hourglass-half"></i> Invoice Generation</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">Service request must be <strong>Approved</strong> or <strong>Completed</strong> before an invoice can be generated.</p>
                            <button class="btn btn-secondary" disabled>
                                <i class="fas fa-file-invoice"></i> Generate Invoice (Not Available)
                            </button>
                        </div>
                    </div>
                }
                else if (Model.Status == RequestStatus.InProgress)
                {
                    <div class="card mt-4 border-warning">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0"><i class="fas fa-spinner fa-spin"></i> Invoice Generation</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">Please complete this service request first to generate an invoice.</p>
                            <button class="btn btn-secondary" disabled>
                                <i class="fas fa-file-invoice"></i> Generate Invoice (Complete First)
                            </button>
                        </div>
                    </div>
                }
                else if (Model.Status == RequestStatus.Cancelled)
                {
                    <div class="card mt-4 border-danger">
                        <div class="card-header bg-danger text-white">
                            <h5 class="mb-0"><i class="fas fa-ban"></i> Invoice Generation</h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted">This service request has been cancelled. No invoice can be generated.</p>
                        </div>
                    </div>
                }

                <!-- Check if invoice already exists -->
                @{
                    var existingInvoice = Context.RequestServices.GetService(typeof(TechMoveGLMS.Data.ApplicationDbContext)) as TechMoveGLMS.Data.ApplicationDbContext;
                    var invoice = existingInvoice?.Invoices.FirstOrDefault(i => i.ServiceRequestId == Model.Id);
                }
                @if (invoice != null)
                {
                    <div class="card mt-4 border-success">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0"><i class="fas fa-check-circle"></i> Invoice Generated</h5>
                        </div>
                        <div class="card-body">
                            <p>An invoice has already been generated for this service request.</p>
                            <p><strong>Invoice Number:</strong> @invoice.InvoiceNumber</p>
                            <p><strong>Invoice Status:</strong> @invoice.Status</p>
                            <a href="/Invoices/Details/@invoice.Id" class="btn btn-info">
                                <i class="fas fa-eye"></i> View Invoice
                            </a>
                        </div>
                    </div>
                }
            </div>

            <div class="col-md-4">
                <!-- Timeline Card -->
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-truck"></i> Request Timeline</h5>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            <div class="mb-3">
                                <i class="fas fa-calendar-plus text-primary"></i>
                                <strong>Created:</strong>
                                <div>@Model.RequestDate.ToString("yyyy-MM-dd HH:mm")</div>
                            </div>
                            @if (Model.Status == RequestStatus.InProgress)
                            {
                                <div class="mb-3">
                                    <i class="fas fa-spinner fa-spin text-warning"></i>
                                    <strong>Status:</strong>
                                    <div>In Progress</div>
                                </div>
                            }
                            @if (Model.Status == RequestStatus.Completed && Model.CompletedDate.HasValue)
                            {
                                <div class="mb-3">
                                    <i class="fas fa-check-circle text-success"></i>
                                    <strong>Completed:</strong>
                                    <div>@Model.CompletedDate.Value.ToString("yyyy-MM-dd HH:mm")</div>
                                </div>
                            }
                            @if (Model.Status == RequestStatus.Approved)
                            {
                                <div class="mb-3">
                                    <i class="fas fa-thumbs-up text-success"></i>
                                    <strong>Status:</strong>
                                    <div>Approved - Ready for processing</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Contract Information Card -->
                <div class="card mt-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-file-contract"></i> Contract Information</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Contract:</strong> @Model.Contract?.Title</p>
                        <p><strong>Service Level:</strong> @Model.Contract?.ServiceLevel</p>
                        <p>
                            <strong>Contract Status:</strong>
                            <span class="status-badge status-@Model.Contract?.Status">
                                @Model.Contract?.Status
                            </span>
                        </p>
                        <p>
                            <strong>Valid Period:</strong><br />
                            @Model.Contract?.StartDate.ToString("yyyy-MM-dd") to @Model.Contract?.EndDate.ToString("yyyy-MM-dd")
                        </p>
                        <a href="/Contracts/Details/@Model.ContractId" class="btn btn-sm btn-outline-primary w-100">
                            <i class="fas fa-eye"></i> View Contract
                        </a>
                    </div>
                </div>

                <!-- Quick Actions Card -->
                <div class="card mt-3">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-bolt"></i> Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <a href="/ServiceRequests" class="btn btn-outline-primary w-100 mb-2">
                            <i class="fas fa-list"></i> All Service Requests
                        </a>
                        @if (Model.Status != RequestStatus.Completed && Model.Status != RequestStatus.Cancelled)
                        {
                            <a href="/ServiceRequests/Create" class="btn btn-outline-success w-100">
                                <i class="fas fa-plus"></i> New Service Request
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>