@model TechMoveGLMS.ViewModels.CreateServiceRequestViewModel
@using TechMoveGLMS.Models

@{
    ViewData["Title"] = "Create Service Request";
    var exchangeRate = ViewBag.ExchangeRate as decimal? ?? 19.50m;
}

<div class="card">
    <div class="card-header bg-success text-white">
        <h3 class="mb-0"><i class="fas fa-plus-circle"></i> Create Service Request</h3>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" id="serviceRequestForm">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="ContractId" class="form-label">Select Contract *</label>
                    <select asp-for="ContractId" class="form-select" id="contractSelect">
                        <option value="">-- Select Active Contract --</option>
                        @foreach (var contract in ViewBag.Contracts)
                        {
                            <option value="@contract.Id">
                                @contract.Title - @contract.Client.Name (Valid until: @contract.EndDate.ToString("yyyy-MM-dd"))
                            </option>
                        }
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="Title" class="form-label">Request Title *</label>
                    <input asp-for="Title" class="form-control" placeholder="Enter request title" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="col-12 mb-3">
                    <label asp-for="Description" class="form-label">Description *</label>
                    <textarea asp-for="Description" rows="4" class="form-control" placeholder="Describe the service needed..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label asp-for="AmountUSD" class="form-label">Amount (USD) *</label>
                    <input asp-for="AmountUSD" type="number" step="0.01" class="form-control" id="amountUSD" placeholder="0.00" />
                    <span asp-validation-for="AmountUSD" class="text-danger"></span>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Amount (ZAR) - Calculated</label>
                    <input type="text" class="form-control bg-light" id="amountZAR" readonly placeholder="Will be calculated automatically" />
                    <small class="text-muted">Exchange Rate: 1 USD = <span id="exchangeRate">@exchangeRate.ToString("F2")</span> ZAR</small>
                </div>
            </div>

            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i> Note: Service requests can only be created for ACTIVE contracts.
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-save"></i> Create Request
                </button>
                <a href="/ServiceRequests" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Live currency conversion
        const amountUSDInput = document.getElementById('amountUSD');
        const amountZARInput = document.getElementById('amountZAR');
        const exchangeRateSpan = document.getElementById('exchangeRate');
        let currentRate = @exchangeRate;

        // Fetch latest exchange rate
        async function fetchExchangeRate() {
            try {
                const response = await fetch('/ServiceRequests/GetExchangeRate');
                const data = await response.json();
                currentRate = data.rate;
                exchangeRateSpan.textContent = currentRate.toFixed(2);
                updateZARAmount();
            } catch (error) {
                console.error('Error fetching exchange rate:', error);
            }
        }

        // Update ZAR amount based on USD input
        function updateZARAmount() {
            const usdAmount = parseFloat(amountUSDInput.value) || 0;
            const zarAmount = usdAmount * currentRate;
            amountZARInput.value = 'R' + zarAmount.toFixed(2);
        }

        // Event listeners
        amountUSDInput.addEventListener('input', updateZARAmount);
        
        // Fetch fresh rate on page load
        fetchExchangeRate();
        
        // Refresh rate every 5 minutes
        setInterval(fetchExchangeRate, 300000);
    </script>
    
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
