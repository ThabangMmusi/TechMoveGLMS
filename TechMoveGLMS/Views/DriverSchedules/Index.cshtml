@model IEnumerable<TechMoveGLMS.Models.DriverSchedule>
@using TechMoveGLMS.Models
@{
    ViewData["Title"] = "All Schedules";
}

<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="fas fa-list me-2"></i> All Driver Schedules</h3>
            <a href="/DriverSchedules/Create" class="btn btn-light rounded-pill px-4">New Schedule</a>
        </div>
        <div class="card-body p-0">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success m-3">@TempData["Success"]</div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-alt fa-3x text-muted mb-3"></i>
                    <p class="text-muted">No schedules found.</p>
                    <a href="/DriverSchedules/Create" class="btn btn-primary rounded-pill px-4">New Schedule</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Driver Name</th>
                                <th>Phone</th>
                                <th>Vehicle</th>
                                <th>Schedule Date</th>
                                <th>Route</th>
                                <th>Status</th>
                                <th class="text-center pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var schedule in Model)
                            {
                                <tr>
                                    <td class="ps-4">@schedule.Id</td>
                                    <td class="fw-semibold">@schedule.DriverName</td>
                                    <td>@(string.IsNullOrEmpty(schedule.DriverPhone) ? "—" : schedule.DriverPhone)</td>
                                    <td>@(string.IsNullOrEmpty(schedule.VehicleNumber) ? "—" : schedule.VehicleNumber)</td>
                                    <td>@schedule.ScheduleDate.ToString("yyyy-MM-dd")</td>
                                    <td><small>@schedule.PickupLocation → @schedule.DeliveryLocation</small></td>
                                    <td>
                                        <span class="badge @(schedule.Status == TripStatus.Scheduled ? "bg-info" : schedule.Status == TripStatus.InProgress ? "bg-warning" : schedule.Status == TripStatus.Completed ? "bg-success" : "bg-danger") rounded-pill px-3 py-2">
                                            @schedule.Status
                                        </span>
                                    </td>
                                    <td class="text-center pe-4">
                                        <a href="/DriverSchedules/Details/@schedule.Id" class="btn btn-sm btn-outline-primary rounded-pill me-1">View</a>
                                        <form method="post" asp-action="Delete" style="display:inline">
                                            <input type="hidden" name="id" value="@schedule.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill" onclick="return confirm('Delete this schedule?')">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>