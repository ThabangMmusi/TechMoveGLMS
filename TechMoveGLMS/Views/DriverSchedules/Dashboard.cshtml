@model IEnumerable<TechMoveGLMS.Models.DriverSchedule>
@using TechMoveGLMS.Models
@{
    ViewData["Title"] = "Driver Schedule Dashboard";
    var currentFilter = ViewBag.CurrentFilter as string ?? "upcoming";
}

<!DOCTYPE html>
<html>
<head>
    <style>
        .stat-card {
            background: white;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }
        .stat-number { font-size: 32px; font-weight: bold; margin-bottom: 5px; }
        .stat-label { color: #666; font-size: 14px; }
        .trip-card {
            background: white;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            border-left: 4px solid;
        }
        .status-Scheduled { border-left-color: #1976d2; }
        .status-InProgress { border-left-color: #f57c00; }
        .status-Completed { border-left-color: #388e3c; }
        .filter-tab {
            padding: 8px 24px;
            border-radius: 25px;
            background: #f0f2f5;
            color: #666;
            text-decoration: none;
            margin-right: 10px;
        }
        .filter-tab.active { background: #1976d2; color: white; }
        .schedule-date-header {
            font-size: 18px;
            font-weight: 600;
            margin: 20px 0 15px 0;
            padding-bottom: 8px;
            border-bottom: 2px solid #e0e0e0;
        }
        .status-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        .bg-info { background: #e3f2fd; color: #1976d2; }
        .bg-warning { background: #fff3e0; color: #f57c00; }
        .bg-success { background: #e8f5e9; color: #388e3c; }
        .bg-danger { background: #ffebee; color: #dc2626; }
    </style>
</head>
<body>
<div class="container-fluid px-0">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold"><i class="fas fa-chart-line text-primary"></i> Driver Schedule Dashboard</h2>
            <p class="text-muted mt-2">Visual dashboard for managing driver assignments and trip schedules</p>
        </div>
        <a href="/DriverSchedules/Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus me-2"></i>Schedule Trip
        </a>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number" style="color: #1976d2;">@ViewBag.TodayTrips</div>
                <div class="stat-label"><i class="fas fa-calendar-day me-1"></i> Today's Trips</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number" style="color: #f57c00;">@ViewBag.InProgressTrips</div>
                <div class="stat-label"><i class="fas fa-spinner fa-spin me-1"></i> In Progress</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number" style="color: #388e3c;">@ViewBag.ScheduledTrips</div>
                <div class="stat-label"><i class="fas fa-clock me-1"></i> Scheduled</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-number" style="color: #7b1fa2;">@ViewBag.TotalDrivers</div>
                <div class="stat-label"><i class="fas fa-truck me-1"></i> Total Drivers</div>
            </div>
        </div>
    </div>

    <!-- Filter Tabs -->
    <div class="mb-4">
        <a href="/DriverSchedules/Dashboard?filter=upcoming" class="filter-tab @(currentFilter == "upcoming" ? "active" : "")">Upcoming</a>
        <a href="/DriverSchedules/Dashboard?filter=inprogress" class="filter-tab @(currentFilter == "inprogress" ? "active" : "")">In Progress</a>
        <a href="/DriverSchedules/Dashboard?filter=all" class="filter-tab @(currentFilter == "all" ? "active" : "")">All</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4">
            <i class="fas fa-calendar-alt fa-3x text-muted mb-3"></i>
            <p class="text-muted">No schedules found. Click "Schedule Trip" to create one.</p>
            <a href="/DriverSchedules/Create" class="btn btn-primary rounded-pill px-4 mt-2">Schedule Trip</a>
        </div>
    }
    else
    {
        var groupedSchedules = Model.OrderBy(s => s.ScheduleDate).GroupBy(s => s.ScheduleDate.Date);
        foreach (var group in groupedSchedules)
        {
            var date = group.Key;
            string dateLabel = date == DateTime.Today ? "TODAY" : date.ToString("MMMM dd, yyyy").ToUpper();
            <div class="schedule-date-header">
                <i class="fas fa-calendar-alt me-2"></i>@dateLabel
            </div>
            foreach (var trip in group.OrderBy(t => t.DepartureTime))
            {
                <div class="trip-card status-@trip.Status">
                    <div class="row align-items-center">
                        <div class="col-md-4">
                            <div class="d-flex align-items-center">
                                <div class="me-3"><i class="fas fa-user-circle fa-2x text-secondary"></i></div>
                                <div>
                                    <h5 class="mb-0 fw-semibold">@trip.DriverName</h5>
                                    <small class="text-muted">@(string.IsNullOrEmpty(trip.DriverPhone) ? "No phone" : trip.DriverPhone)</small>
                                    <div class="mt-1"><span class="badge bg-secondary">@(string.IsNullOrEmpty(trip.VehicleNumber) ? "No Vehicle" : trip.VehicleNumber)</span></div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="text-center">
                                <div class="fw-semibold">@trip.PickupLocation <i class="fas fa-arrow-right text-secondary mx-2"></i> @trip.DeliveryLocation</div>
                                <div class="mt-2"><small class="text-muted">Depart: @trip.DepartureTime.ToString("HH:mm") → Arrive: @trip.ArrivalTime.ToString("HH:mm")</small></div>
                                @if (!string.IsNullOrEmpty(trip.ReferenceNumber))
                                {
                                    <div class="mt-1"><small class="text-muted">Ref: @trip.ReferenceNumber</small></div>
                                }
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="text-center">
                                <span class="status-badge @(trip.Status == TripStatus.Scheduled ? "bg-info" : trip.Status == TripStatus.InProgress ? "bg-warning" : trip.Status == TripStatus.Completed ? "bg-success" : "bg-danger")">
                                    @trip.Status
                                </span>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <form method="post" asp-action="UpdateStatus" class="d-flex gap-2">
                                <input type="hidden" name="id" value="@trip.Id" />
                                <select name="status" class="form-select form-select-sm rounded-pill" onchange="this.form.submit()">
                                    <option value="0" selected="@(trip.Status == TripStatus.Scheduled)">Scheduled</option>
                                    <option value="1" selected="@(trip.Status == TripStatus.InProgress)">In Progress</option>
                                    <option value="2" selected="@(trip.Status == TripStatus.Completed)">Completed</option>
                                    <option value="3" selected="@(trip.Status == TripStatus.Cancelled)">Cancelled</option>
                                    <option value="4" selected="@(trip.Status == TripStatus.Delayed)">Delayed</option>
                                </select>
                            </form>
                            <a href="/DriverSchedules/Details/@trip.Id" class="btn btn-sm btn-outline-info rounded-pill w-100 mt-1">View Details</a>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(trip.Description))
                    {
                        <div class="mt-2 pt-2 border-top"><small>@trip.Description</small></div>
                    }
                </div>
            }
        }
    }
</div>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>