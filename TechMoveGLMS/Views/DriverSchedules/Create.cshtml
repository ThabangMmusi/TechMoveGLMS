@model TechMoveGLMS.ViewModels.CreateDriverScheduleViewModel
@using TechMoveGLMS.Models
@{
    ViewData["Title"] = "Schedule Trip";
}

<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0 fw-bold"><i class="fas fa-plus-circle text-primary"></i> Schedule New Trip</h2>
                <p class="text-muted mt-2">Create a new driver trip assignment - type any driver name</p>
            </div>
            <a href="/DriverSchedules/Dashboard" class="btn btn-outline-secondary rounded-pill px-4">Back to Dashboard</a>
        </div>

        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3"></div>

                    <h5 class="mb-3 fw-semibold text-primary"><i class="fas fa-user me-2"></i>Driver Information</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="DriverName" class="form-label fw-medium">Driver Name *</label>
                            <input asp-for="DriverName" class="form-control rounded-3" placeholder="Enter driver's full name" list="existingDrivers" />
                            <datalist id="existingDrivers">
                                @if (ViewBag.ExistingDrivers != null)
                                {
                                    @foreach (var driver in ViewBag.ExistingDrivers)
                                    {
                                        <option value="@driver.Name"></option>
                                    }
                                }
                            </datalist>
                            <small class="text-muted">You can type any name - auto-suggest from existing drivers</small>
                            <span asp-validation-for="DriverName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DriverPhone" class="form-label fw-medium">Driver Phone</label>
                            <input asp-for="DriverPhone" class="form-control rounded-3" placeholder="+1-555-123-4567" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="VehicleNumber" class="form-label fw-medium">Vehicle Number</label>
                            <input asp-for="VehicleNumber" class="form-control rounded-3" placeholder="TRK-4521" />
                        </div>
                    </div>

                    <h5 class="mb-3 mt-4 fw-semibold text-primary"><i class="fas fa-route me-2"></i>Trip Information</h5>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="ScheduleDate" class="form-label fw-medium">Schedule Date *</label>
                            <input asp-for="ScheduleDate" class="form-control rounded-3" type="date" />
                            <span asp-validation-for="ScheduleDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="DepartureTime" class="form-label fw-medium">Departure Time *</label>
                            <input asp-for="DepartureTime" class="form-control rounded-3" type="datetime-local" />
                            <span asp-validation-for="DepartureTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="ArrivalTime" class="form-label fw-medium">Arrival Time *</label>
                            <input asp-for="ArrivalTime" class="form-control rounded-3" type="datetime-local" />
                            <span asp-validation-for="ArrivalTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PickupLocation" class="form-label fw-medium">Pickup Location *</label>
                            <input asp-for="PickupLocation" class="form-control rounded-3" placeholder="City, Warehouse, Address" />
                            <span asp-validation-for="PickupLocation" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="DeliveryLocation" class="form-label fw-medium">Delivery Location *</label>
                            <input asp-for="DeliveryLocation" class="form-control rounded-3" placeholder="City, Warehouse, Address" />
                            <span asp-validation-for="DeliveryLocation" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ReferenceNumber" class="form-label fw-medium">Reference Number</label>
                            <input asp-for="ReferenceNumber" class="form-control rounded-3" placeholder="SHP-20280507" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Status" class="form-label fw-medium">Status</label>
                            <select asp-for="Status" class="form-select rounded-3" asp-items="Html.GetEnumSelectList<TripStatus>()"></select>
                        </div>
                        <div class="col-12 mb-3">
                            <label asp-for="Description" class="form-label fw-medium">Description</label>
                            <textarea asp-for="Description" class="form-control rounded-3" rows="2" placeholder="Enter trip details..."></textarea>
                        </div>
                    </div>

                    <hr class="my-4" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill px-4">Schedule Trip</button>
                        <a href="/DriverSchedules/Dashboard" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>