@model TechMoveGLMS.Models.Invoice
@using TechMoveGLMS.Models

@{
    ViewData["Title"] = "Invoice Details";
    var isOverdue = Model.DueDate < DateTime.Today && Model.Status != InvoiceStatus.Paid;
}

<div class="card">
    <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
        <h3 class="mb-0"><i class="fas fa-file-invoice"></i> Invoice @Model.InvoiceNumber</h3>
        <a href="/Invoices" class="btn btn-light">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5>Invoice Details</h5>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered">
                            <tr>
                                <th style="width: 200px;">Invoice Number</th>
                                <td>@Model.InvoiceNumber</td>
                            </tr>
                            <tr>
                                <th>Service Request</th>
                                <td>@(Model.ServiceRequest?.Title ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th>Contract</th>
                                <td>@(Model.ServiceRequest?.Contract?.Title ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th>Client</th>
                                <td>@(Model.ServiceRequest?.Contract?.Client?.Name ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th>Client Email</th>
                                <td>@(Model.ServiceRequest?.Contract?.Client?.Email ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th>Amount (USD)</th>
                                <td>$@Model.AmountUSD.ToString("N2")</td>
                            </tr>
                            <tr>
                                <th>Exchange Rate</th>
                                <td>1 USD = @Model.ExchangeRate.ToString("F2") ZAR</td>
                            </tr>
                            <tr>
                                <th>Amount (ZAR)</th>
                                <td class="fw-bold fs-5">R@Model.AmountZAR.ToString("N2")</td>
                            </tr>
                            <tr>
                                <th>Invoice Date</th>
                                <td>@Model.InvoiceDate.ToString("MMMM dd, yyyy")</td>
                            </tr>
                            <tr>
                                <th>Due Date</th>
                                <td>
                                    @Model.DueDate.ToString("MMMM dd, yyyy")
                                    @if (isOverdue)
                                    {
                                        <span class="badge bg-danger ms-2">OVERDUE</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <th>Status</th>
                                <td>
                                    <span class="badge @(Model.Status == InvoiceStatus.Paid ? "bg-success" : Model.Status == InvoiceStatus.Draft ? "bg-secondary" : "bg-info")">
                                        @Model.Status
                                    </span>
                                </td>
                            </tr>
                            @if (Model.PaidDate.HasValue)
                            {
                                <tr>
                                    <th>Paid Date</th>
                                    <td>@Model.PaidDate.Value.ToString("MMMM dd, yyyy")</td>
                                </tr>
                            }
                            <tr>
                                <th>Notes</th>
                                <td>@(string.IsNullOrEmpty(Model.Notes) ? "No notes" : Model.Notes)</td>
                            </tr>
                            <tr>
                                <th>Created Date</th>
                                <td>@Model.CreatedAt.ToString("MMMM dd, yyyy HH:mm")</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <!-- Actions Card -->
                <div class="card">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-cog"></i> Actions</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Status != InvoiceStatus.Paid && Model.Status != InvoiceStatus.Cancelled)
                        {
                            <form asp-action="UpdateStatus" asp-controller="Invoices" method="post" class="mb-3">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <div class="mb-2">
                                    <select name="status" class="form-select mb-2">
                                        <option value="0">Draft</option>
                                        <option value="1">Sent</option>
                                        <option value="2">Paid</option>
                                        <option value="3">Overdue</option>
                                        <option value="4">Cancelled</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-save"></i> Update Status
                                </button>
                            </form>
                            
                            <form asp-action="MarkAsPaid" asp-controller="Invoices" method="post">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-success w-100" onclick="return confirm('Mark this invoice as paid?')">
                                    <i class="fas fa-check-circle"></i> Mark as Paid
                                </button>
                            </form>
                        }
                        else if (Model.Status == InvoiceStatus.Paid)
                        {
                            <div class="alert alert-success text-center">
                                <i class="fas fa-check-circle"></i> This invoice has been paid.
                                @if (Model.PaidDate.HasValue)
                                {
                                    <br />
                                    <small>Paid on: @Model.PaidDate.Value.ToString("MMMM dd, yyyy")</small>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Payment Instructions -->
                <div class="card mt-3">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-credit-card"></i> Payment Information</h5>
                    </div>
                    <div class="card-body">
                        <p><strong>Bank:</strong> TechMove Logistics Bank</p>
                        <p><strong>Account Name:</strong> TechMove Logistics</p>
                        <p><strong>Account Number:</strong> 123-456-7890</p>
                        <p><strong>Branch Code:</strong> 123456</p>
                        <p><strong>Reference:</strong> @Model.InvoiceNumber</p>
                        <hr />
                        <p><strong>Amount Due:</strong> <span class="fw-bold fs-5">R@Model.AmountZAR.ToString("N2")</span></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>