@model IEnumerable<TechMoveGLMS.Models.Invoice>
@using TechMoveGLMS.Models

@{
    ViewData["Title"] = "Invoices";
}

<div class="card">
    <div class="card-header bg-info text-white">
        <h3 class="mb-0"><i class="fas fa-file-invoice-dollar"></i> Invoice Management</h3>
    </div>
    <div class="card-body">
        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5>Total Invoices</h5>
                        <h2>@ViewBag.TotalInvoices</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5>Total Amount (ZAR)</h5>
                        <h2>R @ViewBag.TotalAmount.ToString("N0")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-dark">
                    <div class="card-body">
                        <h5>Paid Amount</h5>
                        <h2>R @ViewBag.PaidAmount.ToString("N0")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-danger text-white">
                    <div class="card-body">
                        <h5>Overdue</h5>
                        <h2>@ViewBag.OverdueCount</h2>
                    </div>
                </div>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-info text-center">
                <i class="fas fa-info-circle"></i> No invoices yet. Complete a service request and generate an invoice.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Invoice #</th>
                            <th>Client</th>
                            <th>Service Request</th>
                            <th>Amount (USD)</th>
                            <th>Amount (ZAR)</th>
                            <th>Invoice Date</th>
                            <th>Due Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model)
                        {
                            var isOverdue = invoice.DueDate < DateTime.Today && invoice.Status != InvoiceStatus.Paid;
                            <tr class="@(isOverdue ? "table-danger" : "")">
                                <td>@invoice.InvoiceNumber</td>
                                <td>@(invoice.ServiceRequest?.Contract?.Client?.Name ?? "N/A")</td>
                                <td>@(invoice.ServiceRequest?.Title ?? "N/A")</td>
                                <td>$@invoice.AmountUSD.ToString("N2")</td>
                                <td>R@invoice.AmountZAR.ToString("N2")</td>
                                <td>@invoice.InvoiceDate.ToString("yyyy-MM-dd")</td>
                                <td>
                                    @invoice.DueDate.ToString("yyyy-MM-dd")
                                    @if (isOverdue)
                                    {
                                        <span class="badge bg-danger ms-2">Overdue</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge @(invoice.Status == InvoiceStatus.Paid ? "bg-success" : invoice.Status == InvoiceStatus.Draft ? "bg-secondary" : "bg-info")">
                                        @invoice.Status
                                    </span>
                                </td>
                                <td>
                                    <a href="/Invoices/Details/@invoice.Id" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>