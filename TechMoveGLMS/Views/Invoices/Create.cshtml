@model dynamic
@using TechMoveGLMS.Models

@{
    ViewData["Title"] = "Create Invoice";
    var serviceRequest = ViewBag.ServiceRequest as TechMoveGLMS.Models.ServiceRequest;
}

<div class="card">
    <div class="card-header bg-info text-white">
        <h3 class="mb-0"><i class="fas fa-plus-circle"></i> Create Invoice from Service Request</h3>
    </div>
    <div class="card-body">
        @if (serviceRequest != null)
        {
            <div class="alert alert-info">
                <h5>Service Request Details:</h5>
                <p><strong>Title:</strong> @serviceRequest.Title</p>
                <p><strong>Description:</strong> @serviceRequest.Description</p>
                <p><strong>Amount in USD:</strong> $@serviceRequest.AmountUSD.ToString("N2")</p>
                <p><strong>Amount in ZAR:</strong> R@serviceRequest.AmountZAR.ToString("N2")</p>
                <p><strong>Exchange Rate Used:</strong> 1 USD = @serviceRequest.ExchangeRate.ToString("F2") ZAR</p>
            </div>
        }

        <form asp-action="Create" method="post">
            <input type="hidden" name="serviceRequestId" value="@(serviceRequest?.Id)" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Invoice Date *</label>
                    <input type="date" name="invoiceDate" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Due Date *</label>
                    <input type="date" name="dueDate" class="form-control" value="@DateTime.Today.AddDays(30).ToString("yyyy-MM-dd")" required />
                </div>

                <div class="col-12 mb-3">
                    <label class="form-label">Notes (Optional)</label>
                    <textarea name="notes" rows="3" class="form-control" placeholder="Any additional notes for this invoice..."></textarea>
                </div>
            </div>

            <div class="alert alert-warning">
                <i class="fas fa-info-circle"></i> This invoice will be generated based on the service request amount. The exchange rate used is from when the service request was created.
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-success">
                    <i class="fas fa-file-invoice"></i> Generate Invoice
                </button>
                <a href="/ServiceRequests" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>