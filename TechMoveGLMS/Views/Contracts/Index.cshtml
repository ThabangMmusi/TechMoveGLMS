@model IEnumerable<TechMoveGLMS.ViewModels.ContractViewModel>
@using TechMoveGLMS.Models
@{
    ViewData["Title"] = "Contract Management";
    var searchModel = ViewBag.SearchModel as TechMoveGLMS.ViewModels.ContractSearchViewModel;
}

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold"><i class="fas fa-file-contract text-primary"></i> Contract Management</h2>
            <p class="text-muted mt-2">Centralized management page for all client contracts</p>
        </div>
        <a href="/Contracts/Create" class="btn btn-primary rounded-pill px-4">
            <i class="fas fa-plus-circle me-2"></i>New Contract
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="mb-3 fw-semibold"><i class="fas fa-filter me-2 text-secondary"></i>Filter Contracts</h5>
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label small text-muted">Start Date From</label>
                    <input type="date" name="StartDateFrom" class="form-control form-control-sm rounded-3" value="@(searchModel?.StartDateFrom?.ToString("yyyy-MM-dd"))" />
                </div>
              
               
                <div class="col-md-3">
                    <label class="form-label small text-muted">End Date To</label>
                    <input type="date" name="EndDateTo" class="form-control form-control-sm rounded-3" value="@(searchModel?.EndDateTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Status</label>
                    <select name="Status" class="form-select form-select-sm rounded-3">
                        <option value="">All</option>
                        @foreach (ContractStatus status in Enum.GetValues(typeof(ContractStatus)))
                        {
                            <option value="@status" selected="@(searchModel?.Status == status)">@status</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted">Client</label>
                    <select name="ClientId" class="form-select form-select-sm rounded-3">
                        <option value="">All Clients</option>
                        @foreach (var client in ViewBag.Clients)
                        {
                            <option value="@client.Id" selected="@(searchModel?.ClientId == client.Id)">@client.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4"><i class="fas fa-search me-1"></i> Search</button>
                    <a href="/Contracts" class="btn btn-outline-secondary btn-sm rounded-pill px-4"><i class="fas fa-redo me-1"></i> Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-file-contract fa-3x text-muted mb-3"></i>
                    <p class="text-muted mb-3">No contracts found. Click "New Contract" to create one.</p>
                    <a href="/Contracts/Create" class="btn btn-primary rounded-pill px-4"><i class="fas fa-plus-circle me-2"></i>New Contract</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Title</th>
                                <th>Client</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Status</th>
                                <th>Service Level</th>
                                <th class="text-center pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contract in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-medium">@contract.Title</td>
                                    <td>
                                        @contract.ClientName<br />
                                        <small class="text-muted">@contract.ClientEmail</small>
                                    </td>
                                    <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        @contract.EndDate.ToString("yyyy-MM-dd")
                                        @if (contract.IsExpiringSoon && !contract.IsExpired)
                                        {
                                            <span class="badge bg-warning ms-2 rounded-pill">Expiring Soon</span>
                                        }
                                        @if (contract.IsExpired)
                                        {
                                            <span class="badge bg-danger ms-2 rounded-pill">Expired</span>
                                        }
                                    </td>
                                    <td><span class="status-badge status-@contract.Status rounded-pill">@contract.Status</span></td>
                                    <td><span class="badge bg-secondary bg-opacity-10 text-dark rounded-pill px-3 py-2">@contract.ServiceLevel</span></td>
                                    <td class="text-center pe-4">
                                        <a href="/Contracts/Details/@contract.Id" class="btn btn-sm btn-outline-primary rounded-pill me-1"><i class="fas fa-eye"></i></a>
                                        @if (!string.IsNullOrEmpty(contract.SignedAgreementFileName))
                                        {
                                            <a href="/Contracts/DownloadFile/@contract.Id" class="btn btn-sm btn-outline-secondary rounded-pill"><i class="fas fa-download"></i></a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>