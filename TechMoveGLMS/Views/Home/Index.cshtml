@{
    ViewData["Title"] = "Dashboard";
}

<div class="row">
    <div class="col-md-12">
        <div class="bg-primary bg-gradient text-white p-5 rounded mb-4">
            <h1 class="display-4">
                <i class="fas fa-globe"></i> Welcome to TechMove GLMS
            </h1>
            <p class="lead">
                Global Logistics Management System - Centralize your contracts, manage service requests, and track international shipments.
            </p>
            <hr class="my-4 bg-light">
            <p>Manage your logistics operations efficiently with our integrated platform.</p>
            <div class="mt-4">
                <a href="/Contracts" class="btn btn-light btn-lg me-2">
                    <i class="fas fa-file-signature"></i> Manage Contracts
                </a>
                <a href="/ServiceRequests" class="btn btn-outline-light btn-lg">
                    <i class="fas fa-clipboard-list"></i> View Requests
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-primary">
            <div class="card-body text-center">
                <i class="fas fa-file-contract fa-3x text-primary mb-3"></i>
                <h5 class="card-title">Contract Management</h5>
                <p class="card-text">
                    Centralized repository for legal agreements, client details, and SLAs with automated status tracking.
                </p>
                <a href="/Contracts" class="btn btn-primary">View Contracts</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-success">
            <div class="card-body text-center">
                <i class="fas fa-exchange-alt fa-3x text-success mb-3"></i>
                <h5 class="card-title">Currency Conversion</h5>
                <p class="card-text">
                    Real-time USD to ZAR exchange rates via external API for accurate international billing.
                </p>
                <a href="/ServiceRequests/Create" class="btn btn-success">Create Request</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card h-100 border-info">
            <div class="card-body text-center">
                <i class="fas fa-shield-alt fa-3x text-info mb-3"></i>
                <h5 class="card-title">Secure Document Storage</h5>
                <p class="card-text">
                    Upload and manage PDF contracts with secure file storage and validation.
                </p>
                <a href="/Contracts/Create" class="btn btn-info text-white">Upload Contract</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-chart-line"></i> Quick Stats</h5>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-md-4">
                        <h3>@ViewBag.ActiveContracts</h3>
                        <p class="text-muted">Active Contracts</p>
                    </div>
                    <div class="col-md-4">
                        <h3>@ViewBag.PendingRequests</h3>
                        <p class="text-muted">Pending Requests</p>
                    </div>
                    <div class="col-md-4">
                        <h3>@ViewBag.TotalContracts</h3>
                        <p class="text-muted">Total Contracts</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="fas fa-info-circle"></i> System Status</h5>
            </div>
            <div class="card-body">
                <p><i class="fas fa-check-circle text-success"></i> Database: Connected</p>
                <p><i class="fas fa-check-circle text-success"></i> Currency API: Active</p>
                <p><i class="fas fa-check-circle text-success"></i> File Storage: Ready</p>
            </div>
        </div>
    </div>
</div>